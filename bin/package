#!/bin/bash
# Low-level: compile a kernel + produce a .deb
# Short alias for scripts/release/compile_and_package.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/release/compile_and_package.sh" "$@"

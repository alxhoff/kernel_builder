#!/bin/bash
# Run make mrproper on a kernel source tree
# Short alias for scripts/build/kernel/mrproper_kernel.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/build/kernel/mrproper_kernel.sh" "$@"

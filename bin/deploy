#!/bin/bash
# Compile kernel (+modules) and deploy to a device
# Short alias for scripts/deploy/compile_and_deploy_kernel.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/deploy/compile_and_deploy_kernel.sh" "$@"

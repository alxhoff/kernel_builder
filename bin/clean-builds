#!/bin/bash
# Clean out Jetson kernel build artifacts
# Short alias for scripts/cleanup/cleanup_jetson_kernel_builds.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/cleanup/cleanup_jetson_kernel_builds.sh" "$@"

#!/bin/bash
# Compile a kernel (wrapper around kernel_builder.py compile)
# Short alias for scripts/build/kernel/compile_kernel.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/build/kernel/compile_kernel.sh" "$@"

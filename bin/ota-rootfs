#!/bin/bash
# Setup a rootfs as an OTA-ready robot image
# Short alias for scripts/ota/setup_rootfs_as_robot_for_ota.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/ota/setup_rootfs_as_robot_for_ota.sh" "$@"

#!/bin/bash
# Retrieve kernel/system logs from a device over SSH
# Short alias for scripts/device/logs/retrieve_logs.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/device/logs/retrieve_logs.sh" "$@"

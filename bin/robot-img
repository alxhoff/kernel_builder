#!/bin/bash
# Build / manage the robot rootfs system images
# Short alias for scripts/flash/rootfs_prep/system_images_workflow/robot_image_manager.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/flash/rootfs_prep/system_images_workflow/robot_image_manager.sh" "$@"

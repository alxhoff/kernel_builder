#!/bin/bash
# Interactive one-shot build -> package -> tag -> publish
# Short alias for scripts/release/build_and_tag.sh. See bin/README.md for the full list.

set -e
REPO_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." &> /dev/null && pwd)"
exec "$REPO_ROOT/scripts/release/build_and_tag.sh" "$@"

From c8456d51a5fb91bd71080c7ea640ced9af41042c Mon Sep 17 00:00:00 2001
From: Alexander Hoffman <alxhoff@gmail.com>
Date: Tue, 30 Jun 2026 14:01:12 +0200
Subject: [PATCH 43/43] Fix 5.1.2 build gaps from 5.1.5 base kernel differences

Add capture_timeout_ms/VI_CAPTURE_TIMEOUT definitions missing from the
5.1.2 tree, and disable sensor_kernel_tests module build targets whose
source files exist only in the 5.1.5 base kernel.

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 .../drivers/media/platform/tegra/camera/tests/Makefile      | 6 +++---
 kernel/nvidia/include/media/mc_common.h                     | 1 +
 kernel/nvidia/include/media/tegra-v4l2-camera.h             | 1 +
 3 files changed, 5 insertions(+), 3 deletions(-)

diff --git a/kernel/nvidia/drivers/media/platform/tegra/camera/tests/Makefile b/kernel/nvidia/drivers/media/platform/tegra/camera/tests/Makefile
index c979ce75a..3922facda 100644
--- a/kernel/nvidia/drivers/media/platform/tegra/camera/tests/Makefile
+++ b/kernel/nvidia/drivers/media/platform/tegra/camera/tests/Makefile
@@ -9,6 +9,6 @@ obj-y += utils/tegracam_log.o
 
 #######################################
 # Sensor Kernel Tests Module
-obj-$(CONFIG_VIDEO_CAMERA_SKT) += sensor_kernel_tests.o
-sensor_kernel_tests-y += modules/sensor_kernel_tests_core.o
-sensor_kernel_tests-y += modules/sensor_kernel_tests_runner.o
+# obj-$(CONFIG_VIDEO_CAMERA_SKT) += sensor_kernel_tests.o
+# sensor_kernel_tests-y += modules/sensor_kernel_tests_core.o
+# sensor_kernel_tests-y += modules/sensor_kernel_tests_runner.o
diff --git a/kernel/nvidia/include/media/mc_common.h b/kernel/nvidia/include/media/mc_common.h
index 6073f9b0b..d4541779f 100644
--- a/kernel/nvidia/include/media/mc_common.h
+++ b/kernel/nvidia/include/media/mc_common.h
@@ -254,6 +254,7 @@ struct tegra_channel {
 	struct v4l2_fh *fh;
 	bool bypass;
 	bool write_ispformat;
+	int  capture_timeout_ms;
 	bool low_latency;
 	enum tegra_vi_pg_mode pg_mode;
 	bool bfirst_fstart;
diff --git a/kernel/nvidia/include/media/tegra-v4l2-camera.h b/kernel/nvidia/include/media/tegra-v4l2-camera.h
index 99b5e5b97..76a12c486 100644
--- a/kernel/nvidia/include/media/tegra-v4l2-camera.h
+++ b/kernel/nvidia/include/media/tegra-v4l2-camera.h
@@ -59,6 +59,7 @@
 #define TEGRA_CAMERA_CID_SENSOR_DV_TIMINGS         (TEGRA_CAMERA_CID_BASE+108)
 #define TEGRA_CAMERA_CID_LOW_LATENCY         (TEGRA_CAMERA_CID_BASE+109)
 #define TEGRA_CAMERA_CID_VI_PREFERRED_STRIDE (TEGRA_CAMERA_CID_BASE+110)
+#define TEGRA_CAMERA_CID_VI_CAPTURE_TIMEOUT (TEGRA_CAMERA_CID_BASE+111)
 
 /**
  * This is temporary with the current v4l2 infrastructure
-- 
2.54.0


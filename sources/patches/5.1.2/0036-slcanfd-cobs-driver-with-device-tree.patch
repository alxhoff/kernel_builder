+/*
+ * This is an example of how to use the "cartken,slcanfd-cobs"
+ * binding in your board's final .dts file (e.g., tegra234-p3701.dts).
+ *
+ * You must find the UART controller you are physically connected to
+ * (e.g., &serial2, which might map to /dev/ttyTHS2 on a Jetson)
+ * and add the 'slcanfd_gateway' node as its child.
+ */
+
+&uarta {
+	status = "okay";
+
+	slcanfd_gateway: slcanfd-cobs-gateway {
+		compatible = "cartken,slcanfd-cobs";
+		baudrate = <4250000>;
+		parity = "none";
+		/* hw-flow-control; */
+
+		status = "okay";
+		can-clock-frequency = <170000000>;
+
+		can@0 {
+			reg = <0>; /* Protocol index 0 */
+			can-transceiver {
+				max-bitrate = <5000000>;
+			};
+		};
+
+		can@1 {
+			reg = <1>; /* Protocol index 1 */
+			can-transceiver {
+				max-bitrate = <5000000>;
+			};
+		};
+
+		can@2 {
+			reg = <2>; /* Protocol index 2 */
+			can-transceiver {
+				max-bitrate = <5000000>;
+			};
+		};
+	};
+};

From 4018380a06290b0802300629471724f14eccb493 Mon Sep 17 00:00:00 2001
From: Alexander Hoffman <alxhoff@gmail.com>
Date: Fri, 17 Apr 2026 11:22:47 +0200
Subject: [PATCH 38/43] Added the per-port device index to the slcan devices to
 help with udev enumeration

---
 kernel/kernel/drivers/net/can/slcanfd_cobs.c | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/kernel/kernel/drivers/net/can/slcanfd_cobs.c b/kernel/kernel/drivers/net/can/slcanfd_cobs.c
index 91006aaf3..97b6c39f1 100644
--- a/kernel/kernel/drivers/net/can/slcanfd_cobs.c
+++ b/kernel/kernel/drivers/net/can/slcanfd_cobs.c
@@ -946,9 +946,18 @@ static int slcanfd_probe(struct serdev_device *serdev)
         vdev->can.ctrlmode = CAN_CTRLMODE_FD;
 
 		netdev->mtu = CANFD_MTU;
-        
+
         netdev->dev.parent = parent->dev;
 
+        /*
+         * Publish the per-port index as the standard net_device dev_port
+         * attribute. This is emitted atomically with the ADD uevent by
+         * the netdev class, so udev rules keyed on ATTR{dev_port} are
+         * guaranteed to see it (unlike device_create_file()-created
+         * attributes, which race with the ADD event).
+         */
+        netdev->dev_port = vdev->dev_index;
+
         ret = register_candev(netdev);
         if (ret) {
             dev_err(parent->dev, "Failed to register candev %u\n", index);
-- 
2.54.0


From ddcf877f87d9ed586777f256a064ac057ce89c37 Mon Sep 17 00:00:00 2001
From: Alexander Hoffman <alxhoff@gmail.com>
Date: Wed, 17 Jun 2026 09:03:30 +0200
Subject: [PATCH 07/12] Device tree: Enable CAN0 and CAN1 pin multiplexing

Configure the 40-pin header CAN transceiver pin muxing (CAN0/CAN1 on
paa0-paa3) on pinmux_aon so the CAN controllers work without the Jetson
hdr40 overlay. Ported from JP5.1.5 0011; the JP5 soc-base gpio@2430000
pinmux node is replaced by the JP7 &pinmux_aon label and TEGRA_PIN_*
macros (same pins, functions and tristate/input settings).

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 .../t23x/nv-public/cartken-10-GMSL.dtsi       | 36 +++++++++++++++++++
 1 file changed, 36 insertions(+)

diff --git a/hardware/nvidia/t23x/nv-public/cartken-10-GMSL.dtsi b/hardware/nvidia/t23x/nv-public/cartken-10-GMSL.dtsi
index 8709acf2c..f0199e3b9 100644
--- a/hardware/nvidia/t23x/nv-public/cartken-10-GMSL.dtsi
+++ b/hardware/nvidia/t23x/nv-public/cartken-10-GMSL.dtsi
@@ -1,4 +1,5 @@
 #include "dt-bindings/clock/tegra234-clock.h"
+#include <dt-bindings/pinctrl/pinctrl-tegra.h>
 
 #define CAM0_PWDN	TEGRA234_MAIN_GPIO(AC, 0)
 #define CAM1_PWDN	TEGRA234_MAIN_GPIO(H, 3)
@@ -1507,3 +1508,38 @@
 			};
 		};
 	};
+
+&pinmux_aon {
+	pinctrl-names = "default";
+	pinctrl-0 = <&cartken_can_pinmux>;
+	cartken_can_pinmux: exp-header-pinmux {
+		hdr40-pin29 {
+			nvidia,pins = "can0_din_paa1";
+			nvidia,function = "can0";
+			nvidia,pin-label = "can0_din";
+			nvidia,tristate = <TEGRA_PIN_ENABLE>;
+			nvidia,enable-input = <TEGRA_PIN_ENABLE>;
+		};
+		hdr40-pin31 {
+			nvidia,pins = "can0_dout_paa0";
+			nvidia,function = "can0";
+			nvidia,pin-label = "can0_dout";
+			nvidia,tristate = <TEGRA_PIN_DISABLE>;
+			nvidia,enable-input = <TEGRA_PIN_DISABLE>;
+		};
+		hdr40-pin33 {
+			nvidia,pins = "can1_dout_paa2";
+			nvidia,function = "can1";
+			nvidia,pin-label = "can1_dout";
+			nvidia,tristate = <TEGRA_PIN_DISABLE>;
+			nvidia,enable-input = <TEGRA_PIN_DISABLE>;
+		};
+		hdr40-pin37 {
+			nvidia,pins = "can1_din_paa3";
+			nvidia,function = "can1";
+			nvidia,pin-label = "can1_din";
+			nvidia,tristate = <TEGRA_PIN_ENABLE>;
+			nvidia,enable-input = <TEGRA_PIN_ENABLE>;
+		};
+	};
+};

From e7ea249df9b8474a5674d9336632bcb54b865e10 Mon Sep 17 00:00:00 2001
From: Alexander Hoffman <alxhoff@gmail.com>
Date: Mon, 23 Mar 2026 14:49:25 +0100
Subject: [PATCH 06/32] d4xx: Improve I2C link stability with timing delays and
 error context logging

- Add usleep_range() delays after I2C read and raw_write operations
  to allow the GMSL2 link to settle, reducing sporadic -121
  (EREMOTEIO) errors on high-speed buses
- Add stack_trace_print() on I2C read/write failures to capture
  call context for debugging intermittent link drops
---
 kernel/nvidia/drivers/media/i2c/d4xx.c | 25 +++++++++++++++++++------
 1 file changed, 19 insertions(+), 6 deletions(-)

diff --git a/kernel/nvidia/drivers/media/i2c/d4xx.c b/kernel/nvidia/drivers/media/i2c/d4xx.c
index a4156e7a5..2def19a25 100644
--- a/kernel/nvidia/drivers/media/i2c/d4xx.c
+++ b/kernel/nvidia/drivers/media/i2c/d4xx.c
@@ -30,6 +30,7 @@
 #include <linux/string.h>
 #include <linux/videodev2.h>
 #include <linux/version.h>
+#include <linux/stacktrace.h>
 #ifdef CONFIG_VIDEO_INTEL_IPU6
 #include <linux/ipu-isys.h>
 #include <media/d4xx_pdata.h>
@@ -516,6 +517,8 @@ static int ds5_write_8(struct ds5 *state, u16 reg, u8 val)
 			dev_dbg(&state->client->dev, "%s(): i2c write 0x%04x: 0x%x\n",
 				 __func__, reg, val);
 
+	usleep_range(100,110);
+
 	return ret;
 }
 #endif
@@ -533,14 +536,21 @@ static int ds5_write(struct ds5 *state, u16 reg, u16 val)
 			__func__, reg, value[1], value[0]);
 
 	ret = regmap_raw_write(state->regmap, reg, value, sizeof(value));
-	if (ret < 0)
+	if (ret < 0) {
+		dev_err(&state->client->dev,
+				"%s(): writing to register: 0x%04x, value1: 0x%x, value2:0x%x\n",
+				__func__, reg, value[1], value[0]);
 		dev_err(&state->client->dev,
 				"%s(): i2c write failed %d, 0x%04x = 0x%x\n",
 				__func__, ret, reg, val);
-	else
+		stack_trace_print(NULL, 0, 4);
+	} else {
 		if (state->dfu_dev.dfu_state_flag == DS5_DFU_IDLE)
 			dev_dbg(&state->client->dev, "%s(): i2c write 0x%04x: 0x%x\n",
 				__func__, reg, val);
+	}
+
+	usleep_range(100,110);
 
 	return ret;
 }
@@ -558,22 +568,23 @@ static int ds5_raw_write(struct ds5 *state, u16 reg,
 			dev_dbg(&state->client->dev,
 					"%s(): i2c raw write 0x%04x: %d bytes\n",
 					__func__, reg, (int)val_len);
-
+	usleep_range(100,110);
 	return ret;
 }
 
 static int ds5_read(struct ds5 *state, u16 reg, u16 *val)
 {
 	int ret = regmap_raw_read(state->regmap, reg, val, 2);
-	if (ret < 0)
+	if (ret < 0){
 		dev_err(&state->client->dev, "%s(): i2c read failed %d, 0x%04x\n",
 				__func__, ret, reg);
-	else {
+		stack_trace_print(NULL, 0, 4);
+	} else {
 		if (state->dfu_dev.dfu_state_flag == DS5_DFU_IDLE)
 			dev_dbg(&state->client->dev, "%s(): i2c read 0x%04x: 0x%x\n",
 					__func__, reg, *val);
 	}
-
+	usleep_range(100,110);
 	return ret;
 }
 
@@ -584,6 +595,8 @@ static int ds5_raw_read(struct ds5 *state, u16 reg, void *val, size_t val_len)
 		dev_err(&state->client->dev, "%s(): i2c read failed %d, 0x%04x\n",
 			__func__, ret, reg);
 
+	usleep_range(100,110);
+
 	return ret;
 }
 
